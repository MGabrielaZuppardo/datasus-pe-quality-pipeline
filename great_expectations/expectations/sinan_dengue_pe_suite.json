{
  "expectation_suite_name": "sinan_dengue_pe_suite",
  "expectations": [
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "NU_NOTIFIC" }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "SE_NOTIFIC" }
    },
    {
      "expectation_type": "expect_column_to_exist",
      "kwargs": { "column": "CO_MUN_NOT" }
    },
    {
      "expectation_type": "expect_compound_columns_to_be_unique",
      "kwargs": {
        "column_list": ["NU_NOTIFIC", "SE_NOTIFIC", "CO_MUN_NOT"]
      }
    },
    {
      "expectation_type": "expect_column_values_to_match_regex",
      "kwargs": {
        "column": "CO_MUN_NOT",
        "regex": "^26\\d{4}$",
        "mostly": 0.95
      }
    }
  ]
}
